{
  "manifest_version": 3,
  "name": "Picklist Impact Checker",
  "version": "1.0.0",
  "description": "Scan Salesforce metadata for hardcoded picklist values that would break when renamed.",
  "permissions": ["cookies", "tabs", "storage"],
  "host_permissions": [
    "https://*.salesforce.com/*",
    "https://*.force.com/*",
    "https://*.my.salesforce.com/*",
    "https://*.lightning.force.com/*",
    "https://*.sandbox.my.salesforce.com/*",
    "https://*.salesforce-setup.com/*",
    "https://*.vf.force.com/*",
    "https://*.visualforce.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.salesforce-setup.com/*"],
      "js": ["content.bundle.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.salesforce.com/*",
        "https://*.my.salesforce.com/*",
        "https://*.sandbox.my.salesforce.com/*",
        "https://*.visual.force.com/*",
        "https://*.vf.force.com/*",
        "https://*.visualforce.com/*",
        "https://*.force.com/*"
      ],
      "js": ["content.bundle.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
